# StockScout v4 Environment Variables

# LLM Provider (anthropic, openai, ollama)
SS4_LLM_PROVIDER=anthropic

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
ALPHA_VANTAGE_API_KEY=...

# Model Configuration
SS4_DEEP_MODEL=claude-sonnet-4-20250514
SS4_QUICK_MODEL=claude-sonnet-4-20250514

# Pipeline Settings
SS4_DEBATE_ROUNDS=2
SS4_ANALYST_TEMP=0.3
SS4_DEBATE_TEMP=0.7

# Intel Sources
PI_WORKSPACE_URL=http://localhost:8080
SS4_TRUMP_V3=true

# Output
SS4_OUTPUT_DIR=./output

# Memory
SS4_SOULMATE=true
