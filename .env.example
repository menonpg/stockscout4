# StockScout v4 — Required Environment Variables
# Set all of these in Railway dashboard before deploying.

# ── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...       # Required — Claude for all agent calls

# ── Market Data ──────────────────────────────────────────────────────────────
FRED_API_KEY=...                   # Required — FRED macro data (VIX, rates, CPI)
FINNHUB_API_KEY=...                # Required — Earnings calendar proximity
ALPHA_VANTAGE_API_KEY=...          # Optional — sector rotation data (yfinance used for most)

# ── AI / Optional ────────────────────────────────────────────────────────────
GEMINI_API_KEY=...                 # Optional — for extended Trump/policy analysis
OPENAI_API_KEY=...                 # Optional — if using OpenAI provider instead of Anthropic

# ── Model Selection ───────────────────────────────────────────────────────────
SS4_DEEP_MODEL=claude-3-5-sonnet-20241022
SS4_QUICK_MODEL=claude-3-5-sonnet-20241022
SS4_LLM_PROVIDER=anthropic

# ── Pipeline Tuning ───────────────────────────────────────────────────────────
SS4_DEBATE_ROUNDS=2
SS4_ANALYST_TEMP=0.3
SS4_DEBATE_TEMP=0.7
SS4_TRUMP_V3=true

# ── Memory (optional) ────────────────────────────────────────────────────────
SS4_SOULMATE=false
