# StockScout v4 — Required Environment Variables
# Set all of these in Railway dashboard before deploying.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Default: azure_openai | Options: azure_openai, anthropic, openai, ollama
SS4_LLM_PROVIDER=azure_openai

# ── Azure OpenAI (default provider) ──────────────────────────────────────────
AZURE_OPENAI_API_KEY=...           # Required — Azure OpenAI API key
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/  # Required
AZURE_OPENAI_DEPLOYMENT=gpt-4o    # Your deployment name in Azure
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Model Selection ───────────────────────────────────────────────────────────
SS4_DEEP_MODEL=gpt-4o              # Maps to Azure deployment name
SS4_QUICK_MODEL=gpt-4o

# ── Anthropic (optional fallback — set SS4_LLM_PROVIDER=anthropic to use) ────
ANTHROPIC_API_KEY=sk-ant-...       # Optional — Claude fallback

# ── OpenAI direct (optional — set SS4_LLM_PROVIDER=openai to use) ────────────
OPENAI_API_KEY=...                 # Optional

# ── Market Data ──────────────────────────────────────────────────────────────
FRED_API_KEY=...                   # Required — FRED macro data (VIX, rates, CPI)
FINNHUB_API_KEY=...                # Required — Earnings calendar proximity
ALPHA_VANTAGE_API_KEY=...          # Optional — sector rotation data

# ── Optional ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=...                 # Optional — extended Trump/policy analysis

# ── Pipeline Tuning ───────────────────────────────────────────────────────────
SS4_DEBATE_ROUNDS=2
SS4_ANALYST_TEMP=0.3
SS4_DEBATE_TEMP=0.7
SS4_TRUMP_V3=true

# ── Memory (optional) ────────────────────────────────────────────────────────
SS4_SOULMATE=false
